// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum GearCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum RentalStatus {
  PENDING
  CONFIRMED
  PICKED_UP
  RETURNED
  COMPLETED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id        String      @id @default(uuid())
  name      String
  email     String      @unique
  password  String

  phone     String?
  avatar    String?

  role      UserRole
  status    UserStatus  @default(ACTIVE)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Provider
  gearItems GearItem[]

  // Customer
  rentalOrders RentalOrder[] @relation("CustomerOrders")

  // Reviews
  reviews Review[]

  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  gearItems   GearItem[]

  @@map("categories")
}

model GearItem {
  id              String         @id @default(uuid())

  providerId      String
  provider        User           @relation(fields: [providerId], references: [id])

  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id])

  name            String
  slug            String         @unique
  brand           String

  description     String

  image           String?

  pricePerDay     Decimal        @db.Decimal(10,2)

  totalStock      Int
  availableStock  Int

  condition       GearCondition

  isAvailable     Boolean        @default(true)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  orderItems      RentalOrderItem[]

  reviews         Review[]

  @@index([providerId])
  @@index([categoryId])
  @@index([brand])
  @@index([isAvailable])
  @@map("gear_items")
}

model RentalOrder {
  id             String           @id @default(uuid())

  customerId     String
  customer       User             @relation("CustomerOrders", fields: [customerId], references: [id])

  startDate      DateTime
  endDate        DateTime

  subtotal       Decimal          @db.Decimal(10,2)
  totalAmount    Decimal          @db.Decimal(10,2)

  status         RentalStatus     @default(PENDING)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  items          RentalOrderItem[]

  payments       Payment[]

  @@index([customerId])
  @@map("rental_orders")
}

model RentalOrderItem {
  id             String        @id @default(uuid())

  rentalOrderId  String
  rentalOrder    RentalOrder   @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)

  gearItemId     String
  gearItem       GearItem      @relation(fields: [gearItemId], references: [id])

  quantity       Int

  pricePerDay    Decimal       @db.Decimal(10,2)

  subtotal       Decimal       @db.Decimal(10,2)

  status         RentalStatus  @default(PENDING)

  review         Review?

  @@index([rentalOrderId])
  @@index([gearItemId])
  @@map("rental_order_items")
}

model Payment {
  id              String            @id @default(uuid())

  rentalOrderId   String
  rentalOrder     RentalOrder       @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)

  transactionId   String            @unique

  provider        PaymentProvider
  currency        String            @default("BDT")

  amount          Decimal           @db.Decimal(10,2)

  status          PaymentStatus     @default(PENDING)

  paidAt          DateTime?

  createdAt       DateTime          @default(now())

  @@index([rentalOrderId])
  @@map("payments")
}

model Review {
  id                String          @id @default(uuid())

  customerId        String
  customer          User            @relation(fields: [customerId], references: [id])

  gearItemId        String
  gearItem          GearItem        @relation(fields: [gearItemId], references: [id])

  rentalOrderItemId String          @unique
  rentalOrderItem   RentalOrderItem @relation(fields: [rentalOrderItemId], references: [id])

  rating            Int

  comment           String?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([gearItemId])

  @@map("reviews")
}